<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KeyforgeDota"
        x:Class="KeyforgeDota.ShortcutConfigWindow"
        x:DataType="local:ShortcutConfigWindow"
        Title="Configurar Atalhos"
        Width="500" Height="520" MinWidth="400" MinHeight="400"
        WindowStartupLocation="CenterOwner">
    <Border Background="#23272F" CornerRadius="12" Padding="16">
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Cabeçalho de colunas -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
                <TextBlock Text="Habilidade" Width="140" Foreground="#B0B3B8" FontWeight="SemiBold"/>
                <TextBlock Text="Atalho 1"   Width="120" Foreground="#B0B3B8" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Atalho 2"   Width="120" Foreground="#B0B3B8" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Lista de atalhos com scroll -->
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Shortcuts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:AbilityShortcut">
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
                                <TextBlock Text="{Binding DisplayName}" Width="140"
                                           Foreground="White" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <local:HotkeyCaptureBox Hotkey="{Binding Shortcut1, Mode=TwoWay}" Width="120"/>
                                <local:HotkeyCaptureBox Hotkey="{Binding Shortcut2, Mode=TwoWay}" Width="120"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Botões -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,12,0,0">
                <Button Name="BtnSalvar"   Content="Salvar"   Background="#5865F2" Foreground="White"   Padding="16,6" MinWidth="80"/>
                <Button Name="BtnCancelar" Content="Cancelar" Background="#2C2F36" Foreground="#F5F6FA" Padding="16,6" MinWidth="80"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
